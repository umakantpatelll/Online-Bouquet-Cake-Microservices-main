		{
			"name": "2. Auth Service - Login",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"if (jsonData.data && jsonData.data.token) {",
							"    pm.globals.set(\"jwt_token\", jsonData.data.token);",
							"}"
						],
						"type": "text/javascript"
					}
				]
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"shivani.patel@gmail.com\",\n  \"password\": \"Password@123\"\n}"
				},
				"url": {
					"raw": "http://localhost:9090/api/auth/login",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "9090",
					"path": [
						"api",
						"auth",
						"login"
					]
				},
				"description": "Logs in the user and stores the JWT token in global variables."
			},
			"response": []
		},
		{
